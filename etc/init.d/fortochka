#!/bin/sh /etc/rc.common
# procd-сервис: сетевую обвязку делает /usr/bin/fortochka, сам Xray супервизит procd.

START=99
STOP=10
USE_PROCD=1

CFG=fortochka
XRAY_BIN=/usr/bin/xray
XRAY_CFG=/etc/xray/config.json

start_service() {
	local enabled mode
	enabled=$(uci -q get "$CFG.main.enabled")
	mode=$(uci -q get "$CFG.main.mode")
	[ "$enabled" = "1" ] || return 0
	[ "$mode" = "off" ] && return 0

	# генерит xray config, грузит nftables, ip-rule/route, dnsmasq nftset
	/usr/bin/fortochka apply || return 1

	procd_open_instance xray
	procd_set_param command "$XRAY_BIN" run -c "$XRAY_CFG"
	procd_set_param respawn 3600 5 5
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_close_instance

	# чистый DNS-резолвер для заблокированных доменов (если DNS включён)
	local dnsargs
	dnsargs=$(/usr/bin/fortochka dns-args 2>/dev/null)
	if [ -n "$dnsargs" ]; then
		procd_open_instance dnsproxy
		procd_set_param command /usr/bin/dnsproxy $dnsargs
		procd_set_param respawn 3600 5 5
		procd_set_param stderr 1
		procd_close_instance
	fi
}

stop_service() {
	/usr/bin/fortochka down
}

reload_service() {
	stop
	start
}

service_triggers() {
	procd_add_reload_trigger "fortochka"
}
